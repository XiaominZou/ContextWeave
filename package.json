{
    "name":  "context-platform-sdk",
    "private":  true,
    "version":  "0.1.0",
    "workspaces":  [
                       "packages/*"
                   ],
    "scripts":  {
                    "test":  "vitest run",
                    "test:core":  "vitest run packages/core/src/__tests__",
                    "typecheck":  "tsc -p packages/core/tsconfig.json --noEmit \u0026\u0026 tsc -p packages/client/tsconfig.json --noEmit \u0026\u0026 tsc -p packages/testing/tsconfig.json --noEmit \u0026\u0026 tsc -p packages/benchmark/tsconfig.json --noEmit \u0026\u0026 tsc -p packages/adapter-kit/tsconfig.json --noEmit \u0026\u0026 tsc -p packages/adapter-openclaw/tsconfig.json --noEmit \u0026\u0026 tsc -p packages/adapter-opencode/tsconfig.json --noEmit",
                    "demo":  "vitest run packages/client/src/__tests__/context-platform-demo.test.ts",
                    "build":  "tsc -p packages/core/tsconfig.json \u0026\u0026 tsc -p packages/adapter-kit/tsconfig.json \u0026\u0026 tsc -p packages/testing/tsconfig.json \u0026\u0026 tsc -p packages/benchmark/tsconfig.json \u0026\u0026 tsc -p packages/client/tsconfig.json \u0026\u0026 tsc -p packages/adapter-openclaw/tsconfig.json \u0026\u0026 tsc -p packages/adapter-opencode/tsconfig.json",
                    "benchmark:smoke":  "npm run build && tsx packages/benchmark/scripts/run-benchmark.ts --smoke",
                    "benchmark:all":  "npm run build && tsx packages/benchmark/scripts/run-benchmark.ts",
                    "benchmark:opencode:real":  "npm run build && tsx packages/benchmark/scripts/run-opencode-real-probe.ts",
                    "benchmark:opencode:real-smoke":  "npm run build && tsx packages/benchmark/scripts/run-opencode-real-probe.ts --smoke",
                    "benchmark:opencode:real-benchmark":  "npm run build && tsx packages/benchmark/scripts/run-opencode-real-benchmark.ts",
                    "benchmark:opencode:real-benchmark-smoke":  "npm run build && tsx packages/benchmark/scripts/run-opencode-real-benchmark.ts --smoke",
                    "benchmark:opencode:warm-benchmark":  "npm run build && tsx packages/benchmark/scripts/run-opencode-warm-benchmark.ts",
                    "benchmark:opencode:warm-benchmark-smoke":  "npm run build && tsx packages/benchmark/scripts/run-opencode-warm-benchmark.ts --smoke",
                    "benchmark:demo-page":  "node scripts/generate-benchmark-demo.mjs",
                    "openclaw:daemon":  "node --experimental-strip-types --loader ./scripts/ctx-node-loader.mjs scripts/openclaw-platform-daemon.mjs",
                    "openclaw:install-plugin":  "node scripts/install-openclaw-plugin.mjs",
                    "opencode:daemon":  "node scripts/opencode-platform-daemon.mjs",
                    "opencode:install-plugin":  "node scripts/install-opencode-plugin.mjs"
                },
    "devDependencies":  {
                            "@types/node":  "^25.5.0",
                            "tsx":  "^4.20.6",
                            "typescript":  "^5.6.3",
                            "vitest":  "^3.2.4"
                        }
}
